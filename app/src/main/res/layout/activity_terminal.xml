<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/terminalRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_background"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_ssh_terminal"
            android:textColor="@color/terminal_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/outputScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1"
        android:background="@drawable/terminal_output_background"
        android:padding="12dp">

        <TextView
            android:id="@+id/outputTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/terminal_text"
            android:textIsSelectable="true"
            android:textSize="8sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/commandEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/primary"
            android:hint="@string/hint_terminal_command"
            android:imeOptions="actionSend"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textColorHint="@color/terminal_text_muted" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_send"
            android:padding="12dp"
            android:src="@drawable/ic_send_24" />

        <ImageButton
            android:id="@+id/copyCommandButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_copy_command"
            android:padding="12dp"
            android:src="@drawable/ic_content_copy_24" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/exitButton"
            android:layout_width="76dp"
            android:layout_height="48dp"
            android:background="@drawable/button_danger"
            android:text="@string/action_exit"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/autocompleteButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_autocomplete"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_forward_24" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/previousCommandButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_previous_command"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_upward_24" />

        <ImageButton
            android:id="@+id/nextCommandButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_next_command"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_downward_24" />
    </LinearLayout>
</LinearLayout>
